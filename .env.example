# ============ 数据库 ============
# 异步连接串：postgresql+asyncpg://用户:密码@主机:端口/库名
DATABASE_URL=postgresql+asyncpg://zhiyuan:zhiyuan_dev_pwd@localhost:5432/zhiyuan
# 同步连接串（Alembic 迁移用）
DATABASE_URL_SYNC=postgresql+psycopg2://zhiyuan:zhiyuan_dev_pwd@localhost:5432/zhiyuan

# ============ 应用 ============
APP_NAME=zhiyuan-backend
APP_ENV=development
LOG_LEVEL=INFO

# ============ LLM ============
# DeepSeek API Key（从 https://platform.deepseek.com 获取）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ============ 微信 ============
# 公众号 AppID 与 Secret（从公众号后台获取）
WECHAT_APPID=
WECHAT_SECRET=

# ============ 爬虫 ============
# 公众号平台登录态（来自 mp.weixin.qq.com）
WECHAT_MP_COOKIE=
WECHAT_MP_TOKEN=
