# ============================================================
# 智源后端环境变量示例
# 复制为 .env 后按需修改；.env 已在 .gitignore，不会被提交
# ============================================================

# ---- 应用 ----
APP_NAME=zhiyuan-backend
APP_ENV=development           # development / production
LOG_LEVEL=INFO

# ---- 数据库（与 docker-compose.yml 中保持一致） ----
DATABASE_URL=postgresql+asyncpg://zhiyuan:zhiyuan_dev_pwd@localhost:5432/zhiyuan
DATABASE_URL_SYNC=postgresql+psycopg2://zhiyuan:zhiyuan_dev_pwd@localhost:5432/zhiyuan

# ---- LLM (DeepSeek) ----
# 必填：申请地址 https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- RAG ----
CHAT_TOP_K=5

# ---- 向量检索（M2 动态 RAG） ----
# embedding_provider: zhipu / openai / disabled
# disabled 时 retrieval.py 走纯关键词检索，无需任何 API Key 即可本地起服务
EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=embedding-3
EMBEDDING_DIM=1024
# 时间衰减系数：score = cos_sim * exp(-lambda * age_days)
# 0.05 ≈ 14 天半衰期；越大越偏好新内容
TIME_DECAY_LAMBDA=0.05
# 智谱 BigModel（https://open.bigmodel.cn 申请），EMBEDDING_PROVIDER=zhipu 时启用
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ---- 调度器（M1 动态爬取） ----
# 关闭后 uvicorn 启动不会触发自动爬取，便于纯前端开发
SCHEDULER_ENABLED=true

# ---- CORS ----
# "*" 允许全部；上线后改成具体域名，逗号分隔
# 例：CORS_ORIGINS=https://zhiyuan.example.com,https://www.zhiyuan.example.com
CORS_ORIGINS=*

# ---- 前端静态目录（相对项目根） ----
FRONTEND_DIR=frontend

# ---- 微信登录（暂未启用，留空即可） ----
WECHAT_APPID=
WECHAT_SECRET=

# ---- 公众号爬虫（如启用 wechat_mp spider 才需要） ----
WECHAT_MP_COOKIE=
WECHAT_MP_TOKEN=
